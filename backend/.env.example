# LLM Provider
RAG_LLM_PROVIDER=gemini
RAG_GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-1.5-flash
RAG_OLLAMA_MODEL=qwen2.5:7b
RAG_OLLAMA_BASE_URL=http://localhost:11434

# Embedding
RAG_EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder

# RAG Pipeline
RAG_RETRIEVAL_STRATEGY=hybrid
RAG_CHUNKING_STRATEGY=document
RAG_USE_RERANKING=true
RAG_USE_QUERY_ENHANCEMENT=false
RAG_TOP_K=5

# CLIP
RAG_IMAGE_MATCH_THRESHOLD=0.25
